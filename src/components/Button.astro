---
import './Button.css';

interface Props {
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  external?: boolean;
}

const { variant = 'primary', size = 'md', href, external } = Astro.props;
const className = `btn btn--${variant} btn--${size}`;
---
{href ? (
  <a
    href={href}
    class={className}
    {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
  >
    <slot />
  </a>
) : (
  <button class={className}>
    <slot />
  </button>
)}
