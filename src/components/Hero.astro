---
import Button from './Button.astro';
import SwimmerSvg from '../assets/silhouettes/swimmer.svg?raw';
import CyclistSvg from '../assets/silhouettes/cyclist.svg?raw';
import RunnerSvg from '../assets/silhouettes/runner.svg?raw';
import './Hero.css';

/**
 * Extract the inner content and viewBox from a raw SVG string
 * so we can define it once as a <symbol> and reuse with <use>.
 */
function extractSvgParts(raw: string) {
  const viewBoxMatch = raw.match(/viewBox="([^"]+)"/);
  const fillMatch = raw.match(/fill="([^"]+)"/);
  // Extract everything between the opening <svg ...> and closing </svg>
  const innerMatch = raw.match(/<svg[^>]*>([\s\S]*)<\/svg>/);
  return {
    viewBox: viewBoxMatch?.[1] ?? '0 0 100 100',
    fill: fillMatch?.[1] ?? 'currentColor',
    inner: innerMatch?.[1]?.trim() ?? '',
  };
}

const swimmer = extractSvgParts(SwimmerSvg);
const cyclist = extractSvgParts(CyclistSvg);
const runner = extractSvgParts(RunnerSvg);

const symbols = [
  { id: 'sil-swimmer', ...swimmer },
  { id: 'sil-cyclist', ...cyclist },
  { id: 'sil-runner', ...runner },
];

// Pattern: swimmer, cyclist, runner × 2 = 6 items per set, duplicated for seamless marquee
const itemIds = ['sil-swimmer', 'sil-cyclist', 'sil-runner', 'sil-swimmer', 'sil-cyclist', 'sil-runner'];
---
<section class="hero">
  {/* Hidden SVG sprite — each silhouette defined once */}
  <svg xmlns="http://www.w3.org/2000/svg" style="display:none">
    {symbols.map(({ id, viewBox, inner }) => (
      <symbol id={id} viewBox={viewBox} fill="currentColor">
        <Fragment set:html={inner} />
      </symbol>
    ))}
  </svg>

  <div class="hero__bg">
    <div class="hero__marquee-strip">
      <div class="hero__marquee-track">
        {itemIds.map((id) => (
          <svg class="hero__silhouette" aria-hidden="true"><use href={`#${id}`} /></svg>
        ))}
        {itemIds.map((id) => (
          <svg class="hero__silhouette" aria-hidden="true"><use href={`#${id}`} /></svg>
        ))}
      </div>
    </div>
    <div class="hero__marquee-strip hero__marquee-strip--reverse">
      <div class="hero__marquee-track">
        {itemIds.map((id) => (
          <svg class="hero__silhouette" aria-hidden="true"><use href={`#${id}`} /></svg>
        ))}
        {itemIds.map((id) => (
          <svg class="hero__silhouette" aria-hidden="true"><use href={`#${id}`} /></svg>
        ))}
      </div>
    </div>
    <div class="hero__marquee-strip">
      <div class="hero__marquee-track">
        {itemIds.map((id) => (
          <svg class="hero__silhouette" aria-hidden="true"><use href={`#${id}`} /></svg>
        ))}
        {itemIds.map((id) => (
          <svg class="hero__silhouette" aria-hidden="true"><use href={`#${id}`} /></svg>
        ))}
      </div>
    </div>
  </div>

  <svg class="hero__deco hero__deco--tri-1" viewBox="0 0 100 87" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M50 2L97 85H3L50 2Z" stroke="currentColor" stroke-width="1.5"/>
  </svg>
  <svg class="hero__deco hero__deco--tri-2" viewBox="0 0 100 87" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M50 2L97 85H3L50 2Z" stroke="currentColor" stroke-width="1.5"/>
  </svg>
  <div class="hero__deco hero__deco--line-1"></div>
  <div class="hero__deco hero__deco--line-2"></div>

  <div class="hero__content">
    <p class="hero__tag">Personalised Endurance Coaching</p>
    <h1 class="hero__title">
      Train Smarter.<br />
      <span class="hero__title-accent">Race Stronger.</span>
    </h1>
    <p class="hero__subtitle">
      Personalised triathlon, running, cycling &amp; swimming coaching programmes built around your life.
    </p>
    <div class="hero__actions">
      <Button href="/contact/" variant="primary" size="lg">
        Book a Free Call
      </Button>
      <Button href="/plans/" variant="outline" size="lg">
        Plans &amp; Pricing
      </Button>
    </div>
  </div>

  <div class="hero__scroll-hint">
    <span>Scroll</span>
    <div class="hero__scroll-line"></div>
  </div>
</section>

<script>
  const hero = document.querySelector('.hero');
  if (hero) {
    const tracks = hero.querySelectorAll<HTMLElement>('.hero__marquee-track');
    const observer = new IntersectionObserver(
      (entries) => {
        const isVisible = entries[0].isIntersecting;
        tracks.forEach((track) => {
          track.style.animationPlayState = isVisible ? 'running' : 'paused';
        });
      },
      { threshold: 0 }
    );
    observer.observe(hero);
  }
</script>
