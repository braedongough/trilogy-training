---
import Section from './Section.astro';
import './CoachProfile.css';

interface Props {
  name: string;
  imageSrc: string;
  bio: string;
  accent: 'accent-1' | 'accent-2';
  reverse?: boolean;
  careerHighs?: string[];
  careerLows?: string[];
}

const { name, imageSrc, bio, accent, reverse = false, careerHighs = [], careerLows = [] } = Astro.props;
const sectionBg = reverse ? 'alt' : 'default';
const sectionDivider = reverse ? 'angle-top' : 'none';
const coachId = `coach-${name.split(' ')[0].toLowerCase()}`;
const hasCareerSection = careerHighs.length > 0 || careerLows.length > 0;
---
<Section background={sectionBg} divider={sectionDivider} id={coachId}>
  <div class={`coach coach--${accent} ${reverse ? 'coach--reverse' : ''}`}>
    <div class="coach__visual">
      <div class="coach__photo-wrap">
        <img src={imageSrc} alt={name} class="coach__photo" loading="lazy" />
      </div>
      <div class={`coach__stripe coach__stripe--${accent}`} aria-hidden="true"></div>
    </div>

    <div class="coach__info">
      <h2 class="coach__name">{name}</h2>
      <p class="coach__bio">{bio}</p>

      {hasCareerSection && (
        <div class="coach__career">
          {careerHighs.length > 0 && (
            <div class="coach__career-section">
              <h3 class={`coach__career-heading coach__career-heading--${accent}`}>Career Highs</h3>
              <ul class="coach__career-list">
                {careerHighs.map((item) => (
                  <li class="coach__career-item">{item}</li>
                ))}
              </ul>
            </div>
          )}
          {careerLows.length > 0 && (
            <div class="coach__career-section">
              <h3 class={`coach__career-heading coach__career-heading--${accent}`}>Career Lows</h3>
              <ul class="coach__career-list">
                {careerLows.map((item) => (
                  <li class="coach__career-item">{item}</li>
                ))}
              </ul>
            </div>
          )}
        </div>
      )}
    </div>
  </div>
</Section>
