---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import ContactForm from '../components/ContactForm';
import './Contact.css';
---
<Layout
  title="Contact Us | Trilogy Training | Book Your Free Consultation"
  description="Book a free consultation call or send us a message. Start your personalised endurance coaching journey today."
  canonicalPath="/contact/"
  ogTitle="Contact Us | Trilogy Training | Book Your Free Consultation"
  ogDescription="Book a free consultation call or send us a message. Start your personalised endurance coaching journey today."
>
  <Section background="default" class="section--page-header contact-hero-section">
    <div class="contact-hero">
      <p class="contact-hero__label">Get in Touch</p>
      <h1 class="contact-hero__title">Let's Talk</h1>
      <p class="contact-hero__subtitle">
        Book a free consultation or drop us a message. We'd love to hear about your goals.
      </p>
    </div>
  </Section>

  <Section background="alt" class="contact-form-section">
    <div class="contact-grid">
      <ContactForm client:load />

      <div class="contact-info">
        <h2 class="contact-info__heading">Prefer to reach out directly?</h2>

        <div class="contact-info__items">
          <a
            href="https://wa.me/447545017670"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-info__item"
          >
            <span class="contact-info__item-icon">&#x1F4AC;</span>
            <span class="contact-info__item-text">
              <span class="contact-info__item-label">WhatsApp (UK)</span>
              +44 7545 017670
            </span>
          </a>

          <a
            href="https://wa.me/41767227296"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-info__item"
          >
            <span class="contact-info__item-icon">&#x1F4AC;</span>
            <span class="contact-info__item-text">
              <span class="contact-info__item-label">WhatsApp (CH)</span>
              +41 76 722 7296
            </span>
          </a>

          <a
            href="https://www.instagram.com/trilogy_training_"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-info__item"
          >
            <span class="contact-info__item-icon">&#x1F4F8;</span>
            <span class="contact-info__item-text">
              <span class="contact-info__item-label">Instagram</span>
              @trilogy_training_
            </span>
          </a>

          <a
            href="https://www.facebook.com/trilogy.tri.training/"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-info__item"
          >
            <span class="contact-info__item-icon">&#x1F44D;</span>
            <span class="contact-info__item-text">
              <span class="contact-info__item-label">Facebook</span>
              Trilogy Training
            </span>
          </a>
        </div>
      </div>
    </div>
  </Section>
</Layout>
